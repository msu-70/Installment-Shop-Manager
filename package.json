{
  "name": "installment-shop",
  "version": "1.0.0",
  "description": "Offline Installment Shop Management System",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'); fs.mkdirSync('node_modules/sqlite3/lib/binding', {recursive:true}); try{fs.copyFileSync('node_modules/sqlite3/build/Release/node_sqlite3.node', 'node_modules/sqlite3/lib/binding/node_sqlite3.node')}catch(e){}\"",
    "dev": "concurrently \"npm run vite\" \"npm run electron:dev\"",
    "vite": "vite",
    "electron:dev": "wait-on http://localhost:5173 && electron .",
    "build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "react-to-print": "^2.15.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.4",
    "electron-builder": "^24.13.3",
    "vite": "^5.1.6",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.installmentshop.app",
    "productName": "Installment Shop Manager",
    "npmRebuild": false,
    "asar": false,
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
